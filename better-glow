#!/usr/bin/env python3
import argparse
import curses
import os
import re
import shutil
import sys
import termios
import tty
from dataclasses import dataclass
from pathlib import Path

RESET = "\x1b[0m"
BOLD = "\x1b[1m"
DIM = "\x1b[2m"
ITALIC = "\x1b[3m"
UNDERLINE = "\x1b[4m"
CYAN = "\x1b[36m"
YELLOW = "\x1b[33m"
MAGENTA = "\x1b[35m"
BLUE = "\x1b[34m"
GREEN = "\x1b[32m"

HEADING_COLORS = {
    1: MAGENTA,
    2: BLUE,
    3: GREEN,
    4: CYAN,
    5: YELLOW,
    6: DIM,
}


@dataclass
class Header:
    level: int
    title: str
    line_no: int


def style(text: str, *codes: str) -> str:
    return "".join(codes) + text + RESET


def apply_inline(md: str) -> str:
    md = re.sub(r"`([^`]+)`", lambda m: style(m.group(1), YELLOW), md)
    md = re.sub(r"\*\*([^*]+)\*\*", lambda m: style(m.group(1), BOLD), md)
    md = re.sub(r"\*([^*]+)\*", lambda m: style(m.group(1), ITALIC), md)
    md = re.sub(
        r"\[([^\]]+)\]\(([^)]+)\)",
        lambda m: f"{style(m.group(1), UNDERLINE)} {style('(' + m.group(2) + ')', DIM)}",
        md,
    )
    return md


def render_markdown_ansi(text: str) -> str:
    out = []
    in_code = False

    for raw in text.splitlines():
        line = raw.rstrip("\n")

        if line.strip().startswith("```"):
            in_code = not in_code
            out.append(style("--- code ---" if in_code else "--- end code ---", DIM))
            continue

        if in_code:
            out.append(style("  " + line, CYAN))
            continue

        if re.match(r"^\s*([-*_])\1\1+\s*$", line):
            out.append(style("─" * 60, DIM))
            continue

        h = re.match(r"^(#{1,6})\s+(.*)$", line)
        if h:
            level = len(h.group(1))
            title = h.group(2).strip()
            color = HEADING_COLORS[level]
            if level <= 2:
                out.append(style(title, BOLD, color))
                out.append(style("─" * max(10, min(80, len(title))), DIM))
            else:
                out.append(style(("  " * (level - 3)) + title, BOLD, color))
            continue

        bq = re.match(r"^\s*>\s?(.*)$", line)
        if bq:
            out.append(style("│ " + apply_inline(bq.group(1)), DIM))
            continue

        li = re.match(r"^(\s*)([-*+]|\d+\.)\s+(.*)$", line)
        if li:
            indent = li.group(1).replace("\t", "    ")
            bullet = li.group(2)
            body = apply_inline(li.group(3))
            out.append(f"{indent}{style('•' if bullet in '-*+' else bullet, BOLD)} {body}")
            continue

        out.append(apply_inline(line))

    return "\n".join(out) + "\n"


def render_markdown_plain(text: str) -> tuple[list[str], list[Header]]:
    lines: list[str] = []
    headers: list[Header] = []
    in_code = False

    for raw in text.splitlines():
        line = raw.rstrip("\n")

        if line.strip().startswith("```"):
            in_code = not in_code
            lines.append("--- code ---" if in_code else "--- end code ---")
            continue

        if in_code:
            lines.append("  " + line)
            continue

        if re.match(r"^\s*([-*_])\1\1+\s*$", line):
            lines.append("-" * 60)
            continue

        h = re.match(r"^(#{1,6})\s+(.*)$", line)
        if h:
            level = len(h.group(1))
            title = h.group(2).strip()
            header_line = len(lines)
            if level <= 2:
                lines.append(title)
                lines.append("-" * max(10, min(80, len(title))))
            else:
                lines.append(("  " * (level - 3)) + title)
            headers.append(Header(level=level, title=title, line_no=header_line))
            continue

        bq = re.match(r"^\s*>\s?(.*)$", line)
        if bq:
            lines.append("| " + bq.group(1))
            continue

        li = re.match(r"^(\s*)([-*+]|\d+\.)\s+(.*)$", line)
        if li:
            indent = li.group(1).replace("\t", "    ")
            bullet = li.group(2)
            marker = "*" if bullet in "-*+" else bullet
            lines.append(f"{indent}{marker} {li.group(3)}")
            continue

        lines.append(line)

    lines.append("")
    return lines, headers


def read_inputs(paths: list[str]) -> str:
    if not paths:
        return sys.stdin.read()

    chunks = []
    for p in paths:
        path = Path(p)
        if not path.exists():
            raise FileNotFoundError(f"file not found: {p}")
        if path.is_dir():
            md_files = sorted(path.rglob("*.md"))
            for f in md_files:
                chunks.append(f"# {f}\n\n" + f.read_text(encoding="utf-8", errors="replace"))
            continue
        chunks.append(path.read_text(encoding="utf-8", errors="replace"))

    return "\n\n".join(chunks)


def read_key(fd: int) -> str:
    ch = os.read(fd, 1).decode("utf-8", errors="ignore")
    if ch != "\x1b":
        return ch

    seq = os.read(fd, 2).decode("utf-8", errors="ignore")
    if seq == "[A":
        return "UP"
    if seq == "[B":
        return "DOWN"
    return ch


def choose_markdown_file(cwd: Path) -> Path | None:
    files = sorted(
        [p for p in cwd.iterdir() if p.is_file() and p.suffix.lower() == ".md"],
        key=lambda p: p.name.lower(),
    )
    if not files:
        print("error: no .md files found in current directory", file=sys.stderr)
        return None

    if not (sys.stdin.isatty() and sys.stdout.isatty()):
        return files[0]

    fd = sys.stdin.fileno()
    old_settings = termios.tcgetattr(fd)
    index = 0
    top = 0

    try:
        tty.setraw(fd)
        while True:
            rows = shutil.get_terminal_size((80, 24)).lines
            header_lines = 3
            footer_lines = 2
            visible = max(5, rows - header_lines - footer_lines)

            if index < top:
                top = index
            elif index >= top + visible:
                top = index - visible + 1

            sys.stdout.write("\x1b[2J\x1b[H")
            sys.stdout.write(f"{BOLD}Select Markdown file{RESET} (Enter=open, q=quit)\n")
            sys.stdout.write(f"{DIM}Current directory: {cwd}{RESET}\n\n")

            end = min(len(files), top + visible)
            for i in range(top, end):
                marker = ">" if i == index else " "
                name = files[i].name
                if i == index:
                    sys.stdout.write(style(f"{marker} {name}", BOLD, UNDERLINE) + "\n")
                else:
                    sys.stdout.write(f"{marker} {name}\n")

            used_lines = header_lines + (end - top)
            padding = max(0, rows - used_lines - footer_lines)
            if padding:
                sys.stdout.write("\n" * padding)
            sys.stdout.write(
                f"{DIM}Keys: Ctrl+N/j/down next | Ctrl+P/k/up prev | Ctrl+F page down | Ctrl+B page up{RESET}\n"
            )
            sys.stdout.write(
                f"{DIM}      g top | G bottom | Enter open | q quit{RESET}\n"
            )
            sys.stdout.flush()

            key = read_key(fd)
            if key in ("\r", "\n"):
                return files[index]
            if key in ("q", "\x03"):
                return None
            if key in ("j", "\x0e", "DOWN"):
                index = min(index + 1, len(files) - 1)
            elif key in ("k", "\x10", "UP"):
                index = max(index - 1, 0)
            elif key == "\x06":
                index = min(index + visible, len(files) - 1)
            elif key == "\x02":
                index = max(index - visible, 0)
            elif key == "g":
                index = 0
            elif key == "G":
                index = len(files) - 1
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)
        sys.stdout.write("\x1b[2J\x1b[H")
        sys.stdout.flush()


def clamp(value: int, lo: int, hi: int) -> int:
    return max(lo, min(hi, value))


def find_active_header(headers: list[Header], scroll: int) -> int:
    active = 0
    for i, h in enumerate(headers):
        if h.line_no <= scroll:
            active = i
        else:
            break
    return active


def draw_line(stdscr: curses.window, y: int, x: int, text: str, width: int, attr: int = 0) -> None:
    clipped = text[: max(0, width)]
    stdscr.addstr(y, x, clipped.ljust(max(0, width)), attr)


def run_tui(lines: list[str], headers: list[Header]) -> int:
    def app(stdscr: curses.window) -> int:
        curses.curs_set(0)
        stdscr.keypad(True)
        curses.mousemask(curses.ALL_MOUSE_EVENTS)

        scroll = 0
        toc_top = 0

        while True:
            height, width = stdscr.getmaxyx()
            footer_h = 1
            body_h = max(1, height - footer_h)

            toc_w = clamp(width // 3, 24, 44)
            if width < 70:
                toc_w = 20
            content_w = max(1, width - toc_w - 1)

            max_scroll = max(0, len(lines) - body_h)
            scroll = clamp(scroll, 0, max_scroll)

            active = find_active_header(headers, scroll) if headers else -1
            if active >= 0:
                if active < toc_top:
                    toc_top = active
                elif active >= toc_top + (body_h - 1):
                    toc_top = active - (body_h - 2)
                toc_top = clamp(toc_top, 0, max(0, len(headers) - 1))

            stdscr.erase()

            draw_line(stdscr, 0, 0, "Headers", toc_w, curses.A_BOLD)
            for row in range(1, body_h):
                idx = toc_top + row - 1
                if idx >= len(headers):
                    draw_line(stdscr, row, 0, "", toc_w)
                    continue
                h = headers[idx]
                label = ("  " * max(0, h.level - 1)) + h.title
                attr = curses.A_REVERSE if idx == active else 0
                draw_line(stdscr, row, 0, label, toc_w, attr)

            for y in range(body_h):
                stdscr.addstr(y, toc_w, "|", curses.A_DIM)

            for row in range(body_h):
                idx = scroll + row
                text = lines[idx] if idx < len(lines) else ""
                draw_line(stdscr, row, toc_w + 1, text, content_w)

            footer = "Keys: Ctrl+N/P j/k lines | Ctrl+F/B pages | Ctrl+D/U half | g/G top/bottom | click header | q quit"
            draw_line(stdscr, height - 1, 0, footer, width, curses.A_REVERSE)

            stdscr.refresh()
            key = stdscr.getch()

            if key in (ord("q"), 27):
                return 0
            if key in (curses.KEY_DOWN, ord("j"), 14):
                scroll += 1
            elif key in (curses.KEY_UP, ord("k"), 16):
                scroll -= 1
            elif key in (curses.KEY_NPAGE, 6):
                scroll += body_h - 1
            elif key in (curses.KEY_PPAGE, 2):
                scroll -= body_h - 1
            elif key == 4:
                scroll += max(1, body_h // 2)
            elif key == 21:
                scroll -= max(1, body_h // 2)
            elif key == ord("g"):
                scroll = 0
            elif key == ord("G"):
                scroll = max_scroll
            elif key in (10, 13) and active >= 0:
                scroll = headers[active].line_no
            elif key == curses.KEY_MOUSE:
                try:
                    _, mx, my, _, bstate = curses.getmouse()
                except curses.error:
                    continue
                if bstate & curses.BUTTON4_PRESSED:
                    scroll -= 3
                elif bstate & curses.BUTTON5_PRESSED:
                    scroll += 3
                elif mx < toc_w and 1 <= my < body_h:
                    idx = toc_top + (my - 1)
                    if 0 <= idx < len(headers):
                        scroll = headers[idx].line_no

    try:
        return curses.wrapper(app)
    except curses.error:
        # Fallback for terminals with limited curses support.
        sys.stdout.write("\n".join(lines) + "\n")
        return 0


def main() -> int:
    parser = argparse.ArgumentParser(description="Standalone markdown viewer with micro-like keybinds")
    parser.add_argument("paths", nargs="*", help="Markdown files or directories")
    parser.add_argument("--no-pager", action="store_true", help="Print rendered markdown directly")
    args = parser.parse_args()

    paths = args.paths
    if not paths and sys.stdin.isatty():
        selected = choose_markdown_file(Path.cwd())
        if selected is None:
            return 0
        paths = [str(selected)]
    elif len(paths) == 1 and Path(paths[0]).is_dir() and sys.stdin.isatty():
        selected = choose_markdown_file(Path(paths[0]))
        if selected is None:
            return 0
        paths = [str(selected)]

    try:
        content = read_inputs(paths)
    except FileNotFoundError as e:
        print(f"error: {e}", file=sys.stderr)
        return 1

    if args.no_pager or not (sys.stdin.isatty() and sys.stdout.isatty()):
        sys.stdout.write(render_markdown_ansi(content))
        return 0

    lines, headers = render_markdown_plain(content)
    return run_tui(lines, headers)


if __name__ == "__main__":
    raise SystemExit(main())
